<Window x:Class="FileSizeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileSizeTool"
        mc:Ignorable="d"
        Title="文件大小查看器" Height="650" Width="900" Icon="icon.ico">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Height="35" FontSize="15" VerticalAlignment="Center" Background="Transparent">
            <MenuItem Header="设置">
                <MenuItem x:Name="MenuItemNewWindow" Header="新窗口打开" IsCheckable="True" Checked="MenuItemSettings_Checked" Unchecked="MenuItemSettings_Unchecked" />
                <MenuItem x:Name="MenuItemUseCache" Header="使用缓存" IsCheckable="True" Checked="MenuItemSettings_Checked" Unchecked="MenuItemSettings_Unchecked" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="MenuItemAbout_Click" />
            </MenuItem>
        </Menu>

        <StackPanel Height="30" Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBlock FontSize="14" Text="请选择或者输入目录：" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="BtnUp" FontSize="14" Content="上一级" Width="80" Margin="0,0,8,0" Click="BtnUp_Click" />
            <TextBox x:Name="TxtPath" FontSize="14" Width="450" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Button x:Name="BtnBrowse" FontSize="14" Content="浏览" Width="80" Margin="0,0,8,0" Click="BtnBrowse_Click" />
            <Button x:Name="BtnScan" FontSize="14" Content="扫描" Width="80" Click="BtnScan_Click" />
        </StackPanel>

        <DataGrid x:Name="DataGridItems" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Items}" CanUserAddRows="False" HeadersVisibility="Column" Margin="0,0,0,8" Sorting="DataGridItems_Sorting">
            <DataGrid.Columns>
                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60"/>
                <DataGridTemplateColumn Header="路径" SortMemberPath="FullPath" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullPath}" TextTrimming="CharacterEllipsis">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制路径" Click="MenuCopyPath_Click" CommandParameter="{Binding}" />
                                        <MenuItem Header="强制删除" Click="MenuForceDelete_Click" CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" SortMemberPath="Size" Width="140"/>
                <DataGridTextColumn Header="类型" Binding="{Binding Type}" SortMemberPath="Type" Width="100"/>
                <DataGridTemplateColumn Header="操作" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="打开" Width="60" Click="BtnOpen_Click" Tag="{Binding}" Margin="0,0,6,0" />
                                <Button Content="扫描" Width="60" Click="BtnScanItem_Click" Tag="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="3" Header="运行日志">
            <TextBox x:Name="TxtConsole" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True">
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="清除记录" Click="MenuClearConsole_Click" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </GroupBox>
    </Grid>
</Window>
